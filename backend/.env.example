NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Supabase/PostgreSQL.
# DATABASE_URL: dùng pooled URL (port 6543) cho runtime/app.
# DIRECT_URL: dùng direct URL (port 5432) cho migrate/seed/test.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=public

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth2 SSO (tuỳ chọn).
# Tạo credentials tại: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
# Nếu chưa có credentials, luồng /auth/google sẽ lỗi riêng và không ảnh hưởng login thường.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Microsoft OAuth2 SSO (tuỳ chọn).
# Azure App Registration redirect URI:
# http://localhost:3000/api/auth/microsoft/callback
# Không hardcode credentials trong source; điền các biến dưới trong backend/.env.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/auth/microsoft/callback
MICROSOFT_SCOPES=openid profile email User.Read
SSO_SUCCESS_REDIRECT_URL=http://localhost:5173/auth/callback
SSO_ERROR_REDIRECT_URL=http://localhost:5173/auth/callback

# Seed/Test control.
# Đặt SKIP_AUTO_SEED=true trong môi trường test/e2e để tránh seed tự động
# gây lỗi "prepared statement" khi dùng PgBouncer pooled URL.
SKIP_AUTO_SEED=false

# Email Service.
# EMAIL_PROVIDER=log   → no-op, chỉ log ra console (mặc định, không cần SMTP).
# EMAIL_PROVIDER=smtp  → gửi email thật qua SMTP nếu các biến SMTP_* hợp lệ.
# Nếu SMTP lỗi hoặc thiếu credential, nghiệp vụ chính vẫn tiếp tục và lỗi được log.
EMAIL_PROVIDER=log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HRM System" <no-reply@example.com>
